# ==========================
# 1. 忽略巨大的模型文件
# ==========================
# 忽略任何目录下的 models 文件夹 (包含你的 Qwen, Llama 等)
**/models/
# 忽略常见的模型权重文件后缀 (双重保险)
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.pkl
cache-*.pkl
*._2log

# ==========================
# 2. 忽略超大的数据文件
# ==========================
# 忽略那个 153MB 的图谱文件
data/processed_data/biomedical/graph.json
# 如果你有其他大数据集，也可以在这里加
# data/processed_data/legal/graph.json

# 【可选】如果你把数据压缩成了 zip，我们要允许上传 zip
!*.zip
!*.tar.gz

# ==========================
# 3. 忽略 Python 编译和缓存
# ==========================
__pycache__/
*.py[cod]
*$py.class

# ==========================
# 4. 忽略日志和输出结果
# ==========================
# 忽略所有 .log 文件 (server_7b.log, Run-4090.log 等)
*.log
logs/
# 忽略生成的预测结果 (通常不需要上传结果，只上传代码)
results/
# 忽略临时文件夹
tmp/

# ==========================
# 5. 忽略 IDE 和 系统文件
# ==========================
.idea/
.vscode/
.DS_Store
*.swp

# ==========================
# 6. 忽略 虚拟环境
# ==========================
venv/
env/
.env
